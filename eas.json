{
  "cli": {
    "version": ">= 16.27.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "FIREBASE_API_KEY": "$FIREBASE_API_KEY_DEV",
        "FIREBASE_AUTH_DOMAIN": "$FIREBASE_AUTH_DOMAIN_DEV",
        "FIREBASE_PROJECT_ID": "$FIREBASE_PROJECT_ID_DEV",
        "FIREBASE_STORAGE_BUCKET": "$FIREBASE_STORAGE_BUCKET_DEV",
        "FIREBASE_MESSAGING_SENDER_ID": "$FIREBASE_MESSAGING_SENDER_ID_DEV",
        "FIREBASE_APP_ID": "$FIREBASE_APP_ID_DEV",
        "FIREBASE_MEASUREMENT_ID": "$FIREBASE_MEASUREMENT_ID_DEV"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "FIREBASE_API_KEY": "$FIREBASE_API_KEY_PROD",
        "FIREBASE_AUTH_DOMAIN": "$FIREBASE_AUTH_DOMAIN_PROD",
        "FIREBASE_PROJECT_ID": "$FIREBASE_PROJECT_ID_PROD",
        "FIREBASE_STORAGE_BUCKET": "$FIREBASE_STORAGE_BUCKET_PROD",
        "FIREBASE_MESSAGING_SENDER_ID": "$FIREBASE_MESSAGING_SENDER_ID_PROD",
        "FIREBASE_APP_ID": "$FIREBASE_APP_ID_PROD",
        "FIREBASE_MEASUREMENT_ID": "$FIREBASE_MEASUREMENT_ID_PROD",
        "SENTRY_DSN": "$SENTRY_DSN",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "andreydev.jpg@gmail.com",
        "ascAppId": "6760212564"
      },
      "android": {
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "andreydev.jpg@gmail.com",
        "ascAppId": "6760212564"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
